    "@semantic-release/git": "^10.0.1",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
